---
---
<button>
    <svg 
        width="70" 
        height="70"
        viewBox="0 0 200 200"
        xmlns="http://www.w3.org/2000/svg"
    >
        <text 
            x="30" 
            y="150"
            font-size="190"
            font-family="var(--font-sans)"
            font-weight="bold"
            fill="var(--color-accent)" 
            class="pink"
            >
            F
            </text>
        <text 
            x="100" 
            y="100" 
            transform="rotate(180) translate(10 50)" 
            transform-origin="140 100"
            font-size="190"
            font-family="var(--font-sans)"
            font-weight="bold"
            fill="var(--color-primary)" 
            class="blue">
            F
        </text>
    </svg>
</button>


<style>
    
    button {
        border: none;
        border-radius: 0;
        padding: 0;
        margin: 0;
        background-color: transparent;
        transition: transform 1s ease-in-out;
    }

    button:hover,
    button:focus,
    button:active {
        transform: rotate(180deg);
    }
</style>