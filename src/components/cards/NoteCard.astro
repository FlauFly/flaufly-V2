---
const { title, url, description, startDate, topics } = Astro.props
---
<a href={url} class="card grid-item" data-topics={topics?.join(",")} id="card">
        <div class="intro">
            <h3 class="title">{title}</h3>
            <p class="description">{description}</p>
        </div>
        <div class="date">
            <span>Published:</span>
            <time>{startDate.toLocaleDateString("pl-PL")}</time>
        </div>
</a>

<style>
    .card {
        margin: var(--space-2xs);
        padding: var(--space-2xs);
        transition: all 0.3s;
        border: 5px solid var(--color-primary);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        color: var(--color-text);
    }

    .card:hover {
        background-color: var(--color-primary-light);
        translate: calc(var(--space-3xs)) calc(-1 * var(--space-3xs));
    }

    .title {
        font-size: var(--font-size-md);
        font-weight: bold;
        text-align: center;
    }

    .description {
        font-size: var(--font-size-sm);
    }

    .date {
        display: flex;
        flex-direction: row;
        gap: var(--space-3xs);
        font-family: var(--font-sans);
        font-size: var(--font-size-sm);
    }
    
    .date span {
        color: var(--color-accent);
        font-weight: bold;
    }

    .date span,
    .date time {
        font-size: var(--font-size-sm);
    }

    .card.hidden {
        display: none;
    }
</style>