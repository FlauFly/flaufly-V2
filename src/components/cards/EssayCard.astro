---
import { Image } from "astro:assets"

const { title, url, description, cover, startDate, updated, topics } = Astro.props;

const wasModified = startDate.toLocaleDateString("pl-PL") !== updated.toLocaleDateString("pl-PL");
---
<div class="card" data-topics={topics?.join(",")} id="card">
    <a class="card-link" href={url}>
            <Image
                src={cover}
                alt=`${title} flag`
                fit='cover'
                layout='full-width'
            />
            <div class="metadata">
                <div class="metadata-info">
                    <h3 class="title">{title}</h3>
                    <p class="description">{description}</p>
                    <div class="date">
                        <span>Published:</span>
                        <time>{startDate.toLocaleDateString("pl-PL")}</time>
                    </div>
                    { 
                        wasModified &&
                        (<div class="date">
                            <span>Updated:</span>
                            <time>{updated.toLocaleDateString("pl-PL")}</time>
                        </div>)
                    }
                </div>
                <div class="topic-cloud">
                    {
                        topics.map((topic: any) => (
                            <span class="topic-box">{topic}</span>
                        ))
                    }
                </div>
            </div>
    </a>
</div>

<style>
    .card {
        transition: all 0.3s;
        border: 0.3rem solid var(--color-primary);
        margin-inline: var(--space-xs);
    }

    .card:hover {
        transform: translateY(calc(-1 * var(--space-2xs)));
    }

    .date {
        display: flex;
        flex-direction: row;
        gap: var(--space-2xs);
        font-family: var(--font-sans);
        margin-inline: var(--space-2xs);

        @media screen and (width >= 1024px) {
            margin-inline: 0;
        }
    }
    
    .date span {
        color: var(--color-accent);
        font-weight: bold;
    }

    .card.hidden {
        display: none;
    }

    .card-link {
        display: flex;
        gap: var(--space-3xs);
        color: var(--color-text);
        flex-direction: column;
        text-align: center;

        @media screen and (width >= 1024px) {
            display: grid;
            grid-template-columns: 35% 1fr;
            text-align: unset;
        }
    }

    .metadata {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .topic-cloud {
        display: flex;
        flex-wrap: wrap;
    }

    .topic-box {
        background-color: var(--color-primary-light);
        border: 5px solid var(--color-primary);
        margin: var(--space-2xs);
        padding: var(--space-3xs);
        display: inline;
    }
</style>